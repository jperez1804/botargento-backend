      "esbuild"
    ]
  },
  "dependencies": {
    "@hono/node-server": "^1.19.12",
    "better-sqlite3": "^12.8.0",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.10",
    "pino": "^10.3.1",
    "ulid": "^3.0.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.5.2",
    "drizzle-kit": "^0.31.10",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vitest": "^2.1.9"
  }
