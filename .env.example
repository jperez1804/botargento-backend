# ===========================================
# BotArgento Embedded Signup Backend
# Copy this file to .env and fill in values
# ===========================================

# Meta / Facebook App (required)
META_APP_ID=                    # Facebook App ID (Meta App Dashboard → Settings → Basic)
META_APP_SECRET=                # Facebook App Secret (Meta App Dashboard → Settings → Basic)
META_CONFIG_ID=                 # Facebook Login for Business config_id

# Meta / Facebook App (optional)
# META_SOLUTION_ID=             # Only needed if using multi-partner solution flow (solutionID)
# META_SYSTEM_USER_TOKEN=       # Only needed for optional token debug/inspection step
META_API_VERSION=v25.0          # Graph API version (default: v25.0)

# Webhooks (required)
META_WEBHOOK_VERIFY_TOKEN=      # Verify token for Meta app-level webhook (must match value set in Meta App Dashboard)

# Security
ENCRYPTION_KEY=                 # 32-byte hex string (64 hex chars). Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ADMIN_API_KEY=                  # Admin endpoint auth key. Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"

# Database
DATABASE_PATH=./data/botargento.db  # SQLite file path. Railway: /data/botargento.db

# Server
CORS_ORIGINS=https://botargento.com.ar,https://www.botargento.com.ar
PORT=3000
NODE_ENV=development            # development | production
LOG_LEVEL=debug                 # pino log level: debug, info, warn, error
